# Copy this file to .env and fill in your values.
# A .env in the project root is auto-loaded by the CLI.

# Get a free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the default Gemini models.
# Reasoning model is used for the final deck synthesis (cost: a few thousand tokens / deck).
# Shortlist model is the cheap pre-filter (cost: ~1k tokens / call) - leave empty to skip the shortlist step.
TCGP_GEMINI_REASONING_MODEL=gemini-2.5-flash
TCGP_GEMINI_SHORTLIST_MODEL=gemini-2.5-flash-lite

# Optional: thinking budget for the reasoning call (tokens). 0 disables thinking.
# Default is 2048, which keeps free-tier usage low while still surfacing real synthesis reasoning.
TCGP_THINKING_BUDGET=2048

# Optional: override the on-disk cache directory.
# TCGP_CACHE_DIR=~/.tcgp_deck_genie
